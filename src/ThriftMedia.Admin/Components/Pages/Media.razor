@page "/media"
@rendermode InteractiveServer

<PageTitle>Media</PageTitle>

<div class="container mt-4">
    <h1>Media Management</h1>
    
    @if (isLoading)
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (mediaItems == null || !mediaItems.Any())
    {
        <div class="alert alert-info">
            <p>No media items found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Media Type</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var media in mediaItems)
                    {
                        <tr>
                            <td>@media.Id</td>
                            <td>@media.Title</td>
                            <td>@media.MediaType</td>
                            <td>
                                <span class="badge bg-@GetStatusBadgeClass(media.Status)">
                                    @media.Status
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewDetails(media.Id)">
                                    View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<MediaItem> mediaItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMediaItems();
    }

    private async Task LoadMediaItems()
    {
        isLoading = true;
        try
        {
            // TODO: Call API to load media items
            await Task.Delay(500); // Simulate API call
            
            // Sample data for now
            mediaItems = new List<MediaItem>
            {
                new() { Id = 1, Title = "Sample Media 1", MediaType = "Book", Status = "Available" },
                new() { Id = 2, Title = "Sample Media 2", MediaType = "DVD", Status = "Sold" },
            };
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewDetails(int id)
    {
        // TODO: Navigate to details page or show modal
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Available" => "success",
        "Sold" => "secondary",
        "Processing" => "warning",
        _ => "info"
    };

    private class MediaItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string MediaType { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
    }
}
