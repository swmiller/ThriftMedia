@page "/"
@inject IJSRuntime JSRuntime

<PageTitle>Thrift Store Media | Search</PageTitle>

<h2 class="text-center">What are you searching for?</h2>

<div class="d-flex justify-content-center mb-3 search-bar-container">
    <div class="input-group position-relative search-input-group">
        <input id="searchInput" @bind="searchText" @oninput="OnInputChanged" @onkeydown="OnKeyDown" class="form-control"
            placeholder="Search..." autocomplete="off" />
        <span class="input-group-append">
            <button class="btn btn-primary search-btn" type="button" @onclick="OnNewSearch">New
                Search</button>
        </span>
        @if (suggestions.Any())
        {
            <ul id="suggestionsList" class="list-group position-absolute suggestions-list">
                @foreach (var suggestion in suggestions)
                {
                    <li class="list-group-item list-group-item-action @(suggestions.IndexOf(suggestion) == selectedIndex ? "active" : "")"
                        @onclick="() => SelectSuggestion(suggestion)">@suggestion
                    </li>
                }
            </ul>
        }
    </div>
</div>

@code {
    private string searchText = string.Empty;
    private int selectedIndex = -1;
    private bool showSearchModal = false;
    private string submittedSearchText = string.Empty;

    // Sample list of fake movie titles for brainstorming
    private List<string> wordList = new List<string>
{
"Shadow of Tomorrow",
"Neon Skyline",
"Echoes in the Mist",
"Quantum Drift",
"Midnight Mirage",
"Lost in the Static",
"Crimson Horizon",
"The Last Broadcast",
"Starlight Rebellion",
"Phantom Protocol",
"Gravity's Edge",
"Silent Avalanche",
"Solaris Run",
"The Forgotten Realm",
"Iron Veil",
"Twilight Paradox",
"Zero Hour",
"The Glass Fortress",
"Pulse of Destiny",
"Infinite Loop",
"The Ember Code",
"Vortex Rising",
"The Sapphire Key",
"Obsidian Dream",
"The Arcadian",
"Digital Ghosts",
"The Velvet Circuit",
"Celestial Outlaws",
"The Final Frame",
"Specter City",
"The Silver Divide"
};

    private List<string> suggestions = new List<string>();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (suggestions.Any())
        {
            switch (e.Key)
            {
                case "ArrowDown":
                    selectedIndex = selectedIndex < suggestions.Count - 1 ? selectedIndex + 1 : 0;
                    break;
                case "ArrowUp":
                    selectedIndex = selectedIndex > 0 ? selectedIndex - 1 : suggestions.Count - 1;
                    break;
                case "Enter":
                    if (selectedIndex >= 0 && selectedIndex < suggestions.Count)
                    {
                        SelectSuggestion(suggestions[selectedIndex]);
                        await FocusSearchInput();
                    }
                    else
                    {
                        // No suggestion selected, submit the search
                        await SubmitSearch();
                    }
                    break;
                case "Escape":
                    suggestions.Clear();
                    selectedIndex = -1;
                    break;
            }
        }
        else if (e.Key == "Enter")
        {
            // No suggestions visible, submit the search
            await SubmitSearch();
        }
    }

    private async Task FocusSearchInput()
    {
        await Task.Delay(100); // Small delay to ensure DOM is updated
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('searchInput').focus()");
    }

    private Task SubmitSearch()
    {
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            submittedSearchText = searchText.Trim();
            showSearchModal = true;
            suggestions.Clear();
            selectedIndex = -1;
        }
        return Task.CompletedTask;
    }

    private void CloseSearchModal()
    {
        showSearchModal = false;
        submittedSearchText = string.Empty;
    }

    private void OnInputChanged(ChangeEventArgs e)
    {
        var input = e.Value?.ToString() ?? string.Empty;
        searchText = input; // Update searchText immediately
        var words = input.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length > 0)
        {
            suggestions = wordList
            .Where(title => words.All(word => title.IndexOf(word, StringComparison.OrdinalIgnoreCase) >= 0))
            .ToList();
            selectedIndex = -1; // Reset selection when suggestions change
        }
        else
        {
            suggestions.Clear();
            selectedIndex = -1;
        }
    }

    private void SelectSuggestion(string suggestion)
    {
        // Replace the last word in the input with the selected suggestion
        var words = searchText.Split(' ', StringSplitOptions.RemoveEmptyEntries).ToList();
        if (words.Count > 0)
        {
            words[words.Count - 1] = suggestion;
            searchText = string.Join(' ', words) + " "; // Add space after selection for continued typing
        }
        else
        {
            searchText = suggestion + " "; // Add space after selection for continued typing
        }
        suggestions.Clear();
        selectedIndex = -1;
    }

    private void OnNewSearch()
    {
        searchText = string.Empty;
        suggestions.Clear();
        selectedIndex = -1;
    }
}

@if (showSearchModal)
{
    <div class="modal fade show d-block search-modal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Search Submitted</h5>
                    <button type="button" class="btn-close" @onclick="CloseSearchModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>Search Query:</strong></p>
                    <p class="bg-light p-2 rounded">@submittedSearchText</p>
                    <p class="text-muted">This is where search processing would occur...</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseSearchModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}