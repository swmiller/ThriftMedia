@page "/"

<PageTitle>Home</PageTitle>

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4">Welcome to ThriftMedia</h1>
        <p class="lead">Find great deals on pre-owned books, DVDs, and more</p>
    </div>
    
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h5 class="card-title mb-3">
                        <span class="bi bi-search"></span> Start Your Search
                    </h5>
                    <p class="card-text">Browse our collection of quality pre-owned media items.</p>
                    <a href="/search" class="btn btn-primary btn-lg">
                        <span class="bi bi-search"></span> Search Now
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <span class="bi bi-book" style="font-size: 3rem; color: #0d6efd;"></span>
                    <h5 class="card-title mt-3">Books</h5>
                    <p class="card-text">Fiction, non-fiction, and more</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <span class="bi bi-disc" style="font-size: 3rem; color: #0d6efd;"></span>
                    <h5 class="card-title mt-3">Movies & Music</h5>
                    <p class="card-text">DVDs, CDs, and vinyl records</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <span class="bi bi-controller" style="font-size: 3rem; color: #0d6efd;"></span>
                    <h5 class="card-title mt-3">Games</h5>
                    <p class="card-text">Video games for all platforms</p>
                </div>
            </div>
        </div>
    </div>
</div>
